<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%-5p %d{HH:mm:ss.SSS} %-20C{1} | %m%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
    <logger name="com.powsybl.openloadflow" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>
    <!-- TRACE makes the tracer wrap every registered LfNetwork listener and log every
         network event to the console: with a long-lived listener (the GPU solver's
         event-driven invalidation), a single 13k-bus slack distribution emits ~8000
         synchronous log lines (~1.2 s), drowning benchmarks. Flip back to TRACE
         locally when event tracing is actually needed. -->
    <logger name="com.powsybl.openloadflow.network.LfNetworkListenerTracer" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>
</configuration>
